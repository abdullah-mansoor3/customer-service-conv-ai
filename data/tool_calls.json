{
  "crm_tests": [
    {
      "id": "crm_get_existing",
      "tool_name": "get_user_info",
      "input": {"user_id": "test_user_001"},
      "expected_fields": ["name", "contact", "preferences", "last_seen"]
    },
    {
      "id": "crm_get_new",
      "tool_name": "get_user_info",
      "input": {"user_id": "brand_new_user_xyz"},
      "expected_contains": "new profile"
    },
    {
      "id": "crm_update_name",
      "tool_name": "update_user_info",
      "input": {"user_id": "test_user_001", "field": "name", "value": "Ahmed Khan"},
      "expected_contains": "Updated"
    },
    {
      "id": "crm_update_contact",
      "tool_name": "update_user_info",
      "input": {"user_id": "test_user_001", "field": "contact", "value": "0300-1234567"},
      "expected_contains": "Updated"
    },
    {
      "id": "crm_update_preference",
      "tool_name": "update_user_info",
      "input": {"user_id": "test_user_001", "field": "preferred_language", "value": "Urdu"},
      "expected_contains": "Updated"
    }
  ],
