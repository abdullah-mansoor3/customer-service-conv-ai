    },
    {
      "id": "rag_tplink_setup",
      "tool_name": "retrieve_isp_knowledge",
      "input": {"query": "TP-Link router configuration setup"},
      "expected_has_context": true
    }
  ],
  "web_search_tests": [
    {
      "id": "ws_ptcl_prices",
      "tool_name": "search_web",
      "input": {"query": "PTCL internet package prices PKR", "max_results": 3},
      "expected_has_results": true
    },
    {
      "id": "ws_nayatel_router",
      "tool_name": "search_web",
      "input": {"query": "Nayatel router model brand", "max_results": 3},
      "expected_has_results": true
    }
  ],
  "support_workflow_tests": [
    {
      "id": "sw_next_question_empty",
      "tool_name": "get_next_best_question",
      "input": {
        "known_state": {
          "router_model": null,
          "lights_status": null,
          "error_message": null,
          "connection_type": null,
          "has_restarted": null
        }
      },
      "expected_target_field": "connection_type"
    },
    {
      "id": "sw_next_question_partial",
      "tool_name": "get_next_best_question",
      "input": {
        "known_state": {
          "router_model": null,
          "lights_status": null,
          "error_message": null,
          "connection_type": "wifi",
          "has_restarted": null
        }
      },
      "expected_target_field": "lights_status"
    },
    {
      "id": "sw_diagnose_red_lights",
      "tool_name": "diagnose_connection_issue",
      "input": {
        "known_state": {
          "router_model": "Huawei",
          "lights_status": "blinking red",
          "error_message": null,
          "connection_type": "wifi",
          "has_restarted": true
        }
      },
      "expected_likely_cause": "Router signal or hardware sync issue"
    },
    {
      "id": "sw_diagnose_wifi",
      "tool_name": "diagnose_connection_issue",
      "input": {
        "known_state": {
          "router_model": "TP-Link",
          "lights_status": "green",
          "error_message": null,
          "connection_type": "wifi",
          "has_restarted": true
        }
      },
      "expected_likely_cause": "Wi-Fi layer issue"
    },
    {
      "id": "sw_diagnose_dns",
      "tool_name": "diagnose_connection_issue",
      "input": {
        "known_state": {
          "router_model": null,
          "lights_status": "green",
          "error_message": "DNS probe finished no internet",
          "connection_type": "ethernet",
          "has_restarted": true
        }
      },
      "expected_likely_cause": "DNS resolution issue"
    },
    {
      "id": "sw_escalate_long_outage",
      "tool_name": "evaluate_escalation",
      "input": {
        "known_state": {
          "router_model": null,
          "lights_status": "no light",
          "error_message": null,
          "connection_type": null,
          "has_restarted": true
        },
        "failed_steps": ["restarted modem", "checked cables", "factory reset"],
        "minutes_without_service": 180
      },
      "expected_escalate": true,
      "expected_priority": "high"
    },
    {
      "id": "sw_no_escalate",
      "tool_name": "evaluate_escalation",
      "input": {
        "known_state": {
          "router_model": "TP-Link",
          "lights_status": "green",
          "error_message": null,
          "connection_type": "wifi",
          "has_restarted": false
        },
        "failed_steps": [],
        "minutes_without_service": 10
      },
      "expected_escalate": false,
      "expected_priority": "none"
    }
  ]
}