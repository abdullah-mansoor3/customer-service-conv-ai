# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copy this to .env and fill in your values
#
#   cp .env.example .env
#
# The .env file is read automatically by Docker Compose and by serve_model.sh.
# It is git-ignored so credentials and local paths are never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Model (required) ─────────────────────────────────────────────────────────
# Path to the GGUF model file INSIDE the container.
# Docker Compose mounts ./models/ → /models/ (read-only).
# Place your .gguf file in the ./models/ directory, then set the filename here.
#
# Example:  MODEL_PATH=/models/mistral-7b-instruct-v0.2.Q4_K_M.gguf
MODEL_PATH=/models/your-model-name.gguf

# Also used by serve_model.sh when running llama-server on the host directly.
# In that case MODEL_PATH should be the full path on your machine:
#   MODEL_PATH=/home/you/models/mistral-7b-instruct-v0.2.Q4_K_M.gguf

# ── LLM inference settings ────────────────────────────────────────────────────
# Context window size in tokens (2048–8192 depending on model & available RAM).
CTX_SIZE=2048

# Number of CPU threads for token generation (auto-detected if unset).
# Set to the number of PHYSICAL cores (not hyperthreads) for best throughput.
# LLAMA_THREADS=4

# ── Backend settings ──────────────────────────────────────────────────────────
# When running with Docker Compose the backend always uses the internal hostname.
# Override this ONLY when running the backend on the host (outside Docker).
# LLAMA_SERVER_URL=http://127.0.0.1:8080

# Number of conversation turns (user + assistant) kept in the LLM context.
MAX_HISTORY=10

# System prompt injected at the start of every conversation.
# Customise to match your business domain.
SYSTEM_PROMPT=You are a helpful customer service assistant specialising in ISP technical support. Be concise and friendly.
